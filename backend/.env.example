# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/pil_lens

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=8h

# Storage Configuration
STORAGE_PATH=./uploads
ENCRYPTION_ENABLED=true
# IMPORTANT: Generate a secure 32-byte (256-bit) key for production
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# GCP Configuration (for production)
GCP_PROJECT_ID=your-project-id
GCP_STORAGE_BUCKET=your-bucket-name
GCP_DOCUMENT_AI_PROCESSOR_ID=your-processor-id

# Claude API Configuration
CLAUDE_API_KEY=your-claude-api-key

# Sentry Configuration
SENTRY_DSN=your-sentry-dsn

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=1000